# Yandex Cloud IAM токен — можно оставить пустым, если используется сервисный аккаунт (см. переменные ниже)
YANDEX_CLOUD_IAM_TOKEN=

# Yandex Cloud Folder ID — взять в настройках каталога
YANDEX_CLOUD_FOLDER_ID=<замените_на_folder_id>

# Путь до JSON-ключа сервисного аккаунта (альтернатива переменной выше).
# Перед запуском скопируйте файл в каталог `secure/`; если файла нет, Docker создаст каталог и сервис не стартует.
YANDEX_CLOUD_SA_KEY_FILE=

# Либо сам JSON-ключ сервисного аккаунта (строка). Используйте при передаче через Secret Manager/CI
YANDEX_CLOUD_SA_KEY_JSON=

# Принудительно соблюдать ночное окно (true) или разрешить дневные тесты (false)
YANDEX_ENFORCE_NIGHT_WINDOW=true

# Когда обрабатывать готовые результаты deferred-операций:
# anytime — можно забирать и разбирать результаты в любое время
# night_only — polling и обработка результатов только в ночное окно 00:00-07:59 по APP_TIMEZONE
# Роли контейнеров: scheduler только ставит deferred-запросы, app только poll/ingest/dedup, worker только enrich/send
YANDEX_RESULTS_PROCESSING_MODE=anytime

# Google Sheets — ID таблицы со списком городов (из URL вида docs.google.com/spreadsheets/d/<ID>/...)
GOOGLE_SHEET_ID=<замените_на_sheet_id>

# Лист (tab) со столбцами city, country, batch_tag, search_malls, search_agencies
GOOGLE_SHEET_TAB=CITIES_INPUT

# Путь до JSON ключа сервисного аккаунта Google (если используете файл)
GOOGLE_SA_KEY_FILE=

# Или передайте содержимое ключа в виде строки JSON
GOOGLE_SA_KEY_JSON=

# Автоматическая синхронизация Google Sheets (true/false)
SHEET_SYNC_ENABLED=false

# Интервал синхронизации в минутах (по умолчанию 60)
SHEET_SYNC_INTERVAL_MINUTES=60

# Обрабатывать только строки с указанным batch_tag (опционально)
SHEET_SYNC_BATCH_TAG=

# Gmail SMTP — единственный SMTP-канал. Данные взять из Google (Security -> App Passwords). Пароль приложения обязательно в кавычки
# Яндекс SMTP — единственный SMTP-канал. Данные взять в Яндекс Почте -> Настройки -> Пароли приложений
YANDEX_SMTP_HOST=smtp.yandex.ru
YANDEX_SMTP_PORT=465
YANDEX_SMTP_SSL=true
YANDEX_USER=<замените_на_yandex_login>
YANDEX_PASS=<замените_на_yandex_app_password>
YANDEX_FROM="Марк Аборчи <mark***@yandex.ru>"

# Управляет фактической отправкой писем (true) или только сохранением в БД (false)
EMAIL_GENERATION_ENABLED=true

# Управляет фактической отправкой писем (true) или только сохранением в БД (false)
EMAIL_SENDING_ENABLED=true

# OpenAI API ключ — получить в личном кабинете OpenAI
OPENAI_API_KEY=<замените_на_openai_api_key>

# Провайдер LLM для генерации outreach-писем:
# openai — текущий контейнер ходит в OpenAI напрямую
# gateway — текущий контейнер ходит в отдельный сервис в разрешённой юрисдикции, а уже он обращается в OpenAI
EMAIL_GENERATION_LLM_PROVIDER=openai

# Модель OpenAI для генерации outreach-писем. Для текущего сценария рекомендуем gpt-5.
EMAIL_GENERATION_LLM_MODEL=gpt-5

# Уровень reasoning для Responses API при генерации писем.
# Для кратких писем и меньшей стоимости/латентности рекомендуем low.
EMAIL_GENERATION_LLM_REASONING_EFFORT=low

# Таймаут одного LLM-запроса на генерацию письма в секундах.
# Для gateway-режима ставьте не меньше 60, иначе нормальная генерация может срываться по timeout.
EMAIL_GENERATION_LLM_TIMEOUT_SECONDS=60

# Базовый URL внешнего LLM gateway-relay для генерации писем. Нужен только при EMAIL_GENERATION_LLM_PROVIDER=gateway.
EMAIL_GENERATION_LLM_GATEWAY_URL=

# Токен доступа к внешнему LLM gateway-сервису для генерации писем.
# Нужен только если gateway защищён Bearer-авторизацией.
EMAIL_GENERATION_LLM_GATEWAY_API_KEY=

# Включает fallback-классификацию через GPT для спорных сайтов: уточняет тип сайта и фактический город
SITE_CLASSIFICATION_LLM_ENABLED=true

# Провайдер fallback-классификации спорных сайтов:
# openai — текущий контейнер ходит в OpenAI напрямую
# gateway — текущий контейнер ходит в отдельный сервис в разрешённой юрисдикции, а уже он обращается в OpenAI
SITE_CLASSIFICATION_LLM_PROVIDER=openai

# Модель OpenAI для fallback-классификации спорных доменов
SITE_CLASSIFICATION_LLM_MODEL=gpt-4.1-mini

# Минимальная уверенность GPT, после которой verdict используем для финального решения
SITE_CLASSIFICATION_LLM_MIN_CONFIDENCE=0.6

# Базовый URL внешнего LLM gateway-relay. Нужен только при SITE_CLASSIFICATION_LLM_PROVIDER=gateway.
# Пример: https://llm-gateway.example.com
SITE_CLASSIFICATION_LLM_GATEWAY_URL=

# Токен доступа к внешнему LLM gateway-сервису. Ищите в secret manager или в переменных CI/CD.
# Нужен только если gateway защищён Bearer-авторизацией.
SITE_CLASSIFICATION_LLM_GATEWAY_API_KEY=

# Включает Playwright fallback для сбора контактов: если статический HTML не дал email,
# сервис откроет страницу в headless Chromium и попробует извлечь контакты уже из полностью
# отрендеренного DOM. Полезно для сайтов на JS/SPA.
CONTACT_ENRICH_PLAYWRIGHT_ENABLED=true

# Таймаут Playwright-рендера одной страницы в секундах
CONTACT_ENRICH_PLAYWRIGHT_TIMEOUT_SECONDS=20

# Таймзона пайплайна — используем московское время для ночных окон
APP_TIMEZONE=Europe/Moscow

# URL Redis — сервис очередей (используем контейнер redis)
REDIS_URL=redis://redis:6379/0
#
# Если нужен доступ к Redis с хоста, создайте `docker-compose.override.yml` и добавьте `ports` для сервиса `redis`

# Пользователь PostgreSQL — указывается в docker-compose и pg_hba
POSTGRES_USER=leadgen

# Пароль PostgreSQL — хранится в секретном менеджере или .env (локально)
POSTGRES_PASSWORD=leadgen_password

# Имя базы PostgreSQL — создаётся автоматически при запуске контейнера
POSTGRES_DB=leadgen

# Хост БД — для приложений внутри docker-compose достаточно db
POSTGRES_HOST=db

# Порт PostgreSQL внутри docker-сети. Для контейнеров проекта должен оставаться 5432.
POSTGRES_PORT=5432

# Внешний порт PostgreSQL для DBeaver / psql с хостовой машины
POSTGRES_EXPOSE_PORT=5433

